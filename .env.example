# ─────────────────────────────────────────────────────────────────────────────
# MediSafe – Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# Google AI / Gemini API Key
# Obtain yours at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# Optional: Gemini model override (default: gemini-2.0-flash)
# GEMINI_MODEL=gemini-2.0-flash

# Optional: Google Cloud Project ID (required only for Vertex AI backend)
# GOOGLE_CLOUD_PROJECT=your-project-id
# GOOGLE_CLOUD_LOCATION=us-central1

# Application settings
MEDISAFE_USER_ID=default_user

# Optional: custom paths (defaults to ~/.medisafe/)
# MEDISAFE_DB_PATH=/path/to/medisafe.db
# MEDISAFE_KEY_PATH=/path/to/encryption.key
